<Window x:Class="CassieWordCheck.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       
        Title="CASSIE CWC Tool"
        Width="880" Height="600"
        MinWidth="680" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Ideal"
        RenderOptions.BitmapScalingMode="HighQuality"
        Loaded="OnMainWindowLoaded">

    <Grid>
        <!-- 氛围光晕装饰 -->
        <Ellipse Width="320" Height="320"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.06"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-80,-80,0"
                 IsHitTestVisible="False" />

        <Grid Margin="24,16,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Toolbar Card (Double-Bezel: 外层毛边 + 内层主体) ──── -->
            <Border Grid.Row="0"
                    Background="#0E0E12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Margin="0,0,0,8"
                    Padding="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.2" ShadowDepth="4" Direction="270" Color="#000000" />
                </Border.Effect>
                <Border x:Name="ToolbarCard"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="12.5"
                        Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Top row: toolbar buttons -->
                    <Grid Grid.Row="0" Margin="16,0,16,0" Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="28" Height="28"
                                CornerRadius="6"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Background="Transparent"
                                VerticalAlignment="Center">
                            <Grid>
                                <!-- 后备色块（图片加载失败时显示玫瑰色圆点） -->
                                <Ellipse Width="16" Height="16"
                                         Fill="{StaticResource AccentGradientBrush}"
                                         Opacity="0.35" />
                                <!-- Clip 显式裁剪圆角，否则 CornerRadius 不会裁子元素 -->
                                <Image x:Name="ToolbarIcon" Width="26" Height="26"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="5" RadiusY="5"
                                                           Rect="0,0,26,26" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Text="CASSIE Word Checker"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />

                        <Button Grid.Column="2"
                                x:Name="WhitelistButton"
                                Style="{StaticResource ModernButton}"
                                Height="32"
                                Content="白名单"
                                Padding="14,6"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Click="OnOpenWhitelist" />

                        <ComboBox Grid.Column="3"
                                  x:Name="ModeCombo"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="110"
                                  Height="32"
                                  Margin="4,0,8,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnModeChanged" />

                        <Button Grid.Column="4"
                                x:Name="StatsButton"
                                Style="{StaticResource ModernButton}"
                                Width="36" Height="32"
                                Padding="0"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="统计面板"
                                Click="OnOpenStatistics">
                            <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Button>

                        <Button Grid.Column="5"
                                x:Name="HistoryButton"
                                Style="{StaticResource ModernButton}"
                                Width="36" Height="32"
                                Padding="0"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="检查历史"
                                Click="OnToggleHistory">
                            <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Button>

                        <Button Grid.Column="6"
                                x:Name="WordCountButton"
                                Style="{StaticResource ModernButton}"
                                Width="36" Height="32"
                                Padding="0"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="字数统计"
                                Click="OnOpenWordCount">
                            <TextBlock Text="✍" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Button>

                        <Button Grid.Column="7"
                                x:Name="WordListBrowserButton"
                                Style="{StaticResource ModernButton}"
                                Height="32"
                                Padding="12,6"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="词库管理"
                                Click="OnOpenWordListBrowser">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📚" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="词库管理" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="8"
                                x:Name="SettingsButton"
                                Style="{StaticResource ModernButton}"
                                Content="⚙"
                                Width="36" Height="32"
                                Padding="0"
                                FontSize="18"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="设置"
                                Click="OnOpenSettings" />

                        <Button Grid.Column="9"
                                x:Name="AboutButton"
                                Style="{StaticResource ModernButton}"
                                Content="ⓘ"
                                Width="36" Height="32"
                                Padding="0"
                                FontSize="18"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="关于"
                                Click="OnOpenAbout" />
                    </Grid>

                <!-- Separator + status line -->
                <Grid Grid.Row="1" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#1A1A2E"
                            CornerRadius="6"
                            Padding="8,4"
                            Margin="20,8">
                        <TextBlock x:Name="WordListInfo"
                                   Text="词库：—"
                                   Foreground="{StaticResource AccentLightBrush}"
                                   FontSize="11"
                                   FontFamily="{StaticResource MonoFont}" />
                    </Border>

                    <TextBlock Grid.Column="2"
                               Margin="0,0,20,0"
                               VerticalAlignment="Center">
                        <Hyperlink x:Name="WordlistPathLink"
                                   Foreground="{StaticResource AccentLightBrush}"
                                   FontSize="11"
                                   FontFamily="{StaticResource MonoFont}"
                                   TextDecorations="Underline"
                                   NavigateUri="javascript:void(0)"
                                   RequestNavigate="OnOpenWordlistLocation">
                            <Run Text="..." />
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Main Content - Input & Result Cards
             ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="0,0,0,8"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform Y="0" />
            </Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Input Card (Double-Bezel) ────────────────── -->
            <Border Grid.Column="0"
                    CornerRadius="14"
                    Background="#0E0E12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.18" ShadowDepth="3" Direction="270" Color="#000000" />
                </Border.Effect>
                <Border x:Name="InputCard"
                        Style="{StaticResource CardStyle}"
                        BorderThickness="0"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12.5"
                        Padding="0"
                        Effect="{x:Null}"
                        RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" x:Name="InputLabel" Text="输入框"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CharCountLabel" Grid.Column="2"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <Button Grid.Column="3"
                                    x:Name="FileOpenButton"
                                    Style="{StaticResource ModernButton}"
                                    Width="28" Height="28"
                                    Padding="0"
                                    ToolTip="打开文件 / 导入单词"
                                    Click="OnFileOpenOrImport">
                                <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Grid.Column="4"
                                    x:Name="ClearButton"
                                    Style="{StaticResource DangerButton}"
                                    Width="28" Height="28"
                                    Padding="0"
                                    Margin="4,0,0,0"
                                    ToolTip="清空输入"
                                    Click="OnClearInput">
                                <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Input text area -->
                    <TextBox x:Name="InputBox"
                             Grid.Row="1"
                             Style="{StaticResource ModernTextBox}"
                             BorderThickness="0"
                             Background="Transparent"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="16,12"
                             FontSize="14"
                             FontFamily="{StaticResource MonoFont}"
                             TextChanged="OnInputTextChanged"
                             PreviewKeyDown="OnInputPreviewKeyDown"
                             PreviewKeyUp="OnInputPreviewKeyUp" />
                </Grid>
            </Border>
        </Border>

            <!-- ─── RIGHT: Result Card (Double-Bezel) ──────────────── -->
            <Border Grid.Column="2"
                    CornerRadius="14"
                    Background="#0E0E12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.18" ShadowDepth="3" Direction="270" Color="#000000" />
                </Border.Effect>
                <Border x:Name="ResultCard"
                        Style="{StaticResource CardStyle}"
                        BorderThickness="0"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12.5"
                        Padding="0"
                        Effect="{x:Null}"
                        RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="0" Y="0" />
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource AccentGradientBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" x:Name="ResultLabel" Text="检查结果"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    x:Name="ExportButton"
                                    Style="{StaticResource ModernButton}"
                                    Padding="12,5"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Margin="0,0,6,0"
                                    Click="OnExportResult">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📤" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="导出" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                            <Button Grid.Column="3"
                                    x:Name="CopyButton"
                                    Style="{StaticResource ModernButton}"
                                    Padding="12,5"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Click="OnCopyResult">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="复制" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                            <Button Grid.Column="4"
                                    x:Name="ResultReplaceButton"
                                    Style="{StaticResource ModernButton}"
                                    Content="替换"
                                    Padding="12,5"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Margin="4,0,0,0"
                                    Click="OnToggleResultReplace" />
                        </Grid>
                    </Border>

                    <!-- 替换栏（跨模式） -->
                    <Border x:Name="ResultReplaceBar"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,8"
                            Background="{StaticResource SurfaceBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       x:Name="ResultReplaceFindLabel"
                                       Text="查找："
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" />
                            <TextBox x:Name="ResultReplaceFindBox" Grid.Column="1"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="6,0,12,0" Padding="6,4"
                                     FontSize="13"
                                     FontFamily="{StaticResource MonoFont}" />
                            <TextBlock Grid.Column="2"
                                       x:Name="ResultReplaceToLabel"
                                       Text="替换为："
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" />
                            <TextBox x:Name="ResultReplaceToBox" Grid.Column="3"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="6,0,8,0" Padding="6,4"
                                     FontSize="13"
                                     FontFamily="{StaticResource MonoFont}"
                                     KeyDown="OnResultReplaceKeyDown" />
                            <Button x:Name="ResultReplaceGoButton" Grid.Column="4"
                                    Style="{StaticResource ModernButton}"
                                    Content="替换"
                                    Padding="10,4"
                                    FontSize="12"
                                    Click="OnResultReplaceConfirm" />
                            <Button Grid.Column="5"
                                    Style="{StaticResource ModernButton}"
                                    Width="24" Height="24"
                                    Padding="0" Margin="4,0,0,0"
                                    Click="OnResultReplaceDismiss">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="15" Width="14" Height="14" VerticalAlignment="Center" TextAlignment="Center" />
                        </Button>
                        </Grid>
                    </Border>

                    <!-- Result display -->
                    <RichTextBox x:Name="ResultBox"
                                 Grid.Row="2"
                                 Style="{StaticResource ModernRichTextBox}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="16,12"
                                 FontSize="14"
                                 FontFamily="{StaticResource MonoFont}"
                                 IsReadOnly="True" />

                    <!-- 列表模式（每个单词一行） -->
                    <Grid x:Name="ListViewContainer"
                          Visibility="Collapsed"
                          Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 替换栏 -->
                        <Border x:Name="ReplaceBar" Grid.Row="0"
                                Visibility="Collapsed"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="16,8"
                                Background="{StaticResource SurfaceBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Name="ReplaceBarLabel"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentLightBrush}"
                                           FontSize="13" />
                                <TextBox x:Name="ReplaceInput" Grid.Column="1"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="8,0" Padding="6,4"
                                         FontSize="13"
                                         FontFamily="{StaticResource MonoFont}"
                                         KeyDown="OnReplaceInputKeyDown" />
                                <Button x:Name="ReplaceConfirmButton" Grid.Column="2"
                                        Style="{StaticResource ModernButton}"
                                        Content="替换"
                                        Padding="10,4"
                                        FontSize="12"
                                        Click="OnReplaceConfirm" />
                                <Button Grid.Column="3"
                                        Style="{StaticResource ModernButton}"
                                        Width="24" Height="24"
                                        Padding="0" Margin="4,0,0,0"
                                        Click="OnReplaceDismiss">
                                <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" TextAlignment="Center" />
                            </Button>
                            </Grid>
                        </Border>

                        <ListView x:Name="ResultListView" Grid.Row="1"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Padding="16,12"
                                  FontSize="14"
                                  FontFamily="{StaticResource MonoFont}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,4" Margin="0,0,0,2"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      Style="{StaticResource ModernCheckBox}"
                                                      Tag="{Binding Text}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"
                                                      Checked="OnReplaceCheckChanged"
                                                      Unchecked="OnReplaceCheckChanged" />
                                            <Ellipse Grid.Column="1" Width="8" Height="8"
                                                     Fill="{Binding StatusColor}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Text}"
                                                       FontSize="14"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="3"
                                                    CornerRadius="4" Padding="6,2"
                                                    Background="{Binding StatusBg}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontSize="11"
                                                           Foreground="{Binding StatusColor}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- 两栏对比模式 -->
                    <Grid x:Name="ResultCompareGrid"
                          Visibility="Collapsed"
                          Grid.Row="2"
                          Margin="16,12,16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 左栏：可用词 -->
                        <Border Grid.Column="0" CornerRadius="8" Background="#0A2E1A"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="可用词" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessBrush}"
                                           Margin="0,0,0,8" />
                                <ListBox x:Name="AvailableList" Grid.Row="1"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       Padding="4,2" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- 分隔线 -->
                        <Border Grid.Column="1" Width="1"
                                Background="{StaticResource BorderBrush}"
                                Margin="12,0" />

                        <!-- 右栏：不可用词 -->
                        <Border Grid.Column="2" CornerRadius="8" Background="#2D1B1B"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="不可用词" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource ErrorBrush}"
                                           Margin="0,0,0,8" />
                                <ListBox x:Name="UnavailableList" Grid.Row="1"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       Padding="4,2" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 单词详情浮窗（鼠标悬停不可用词时弹出） -->
                    <Popup x:Name="WordDetailPopup"
                           Placement="Mouse"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           IsOpen="False">
                        <Border CornerRadius="12"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="16,12"
                                MaxWidth="320">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="3" Direction="270" Color="#000000" />
                            </Border.Effect>
                            <StackPanel>
                                <!-- 单词标题 -->
                                <TextBlock x:Name="PopupWordText"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource ErrorBrush}"
                                           FontFamily="{StaticResource MonoFont}" />

                                <!-- 频率统计 -->
                                <Grid Margin="0,8,0,0">
                                    <Border CornerRadius="6" Background="#2D1B1B" Padding="10,6">
                                        <TextBlock x:Name="PopupFreqText"
                                                   FontSize="11"
                                                   Foreground="{StaticResource ErrorBrush}"
                                                   FontFamily="{StaticResource MonoFont}" />
                                    </Border>
                                </Grid>

                                <!-- 分隔线 -->
                                <Rectangle Height="1" Fill="{StaticResource BorderBrush}"
                                           Margin="0,8,0,8" />

                                <!-- 拼写建议标题 -->
                                <TextBlock x:Name="PopupSuggestionTitle"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" />

                                <!-- 建议列表 -->
                                <ItemsControl x:Name="PopupSuggestionList"
                                              Margin="0,6,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A1A2E"
                                                    CornerRadius="6"
                                                    Padding="8,4" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource AccentLightBrush}"
                                                           FontFamily="{StaticResource MonoFont}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
        </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Suggestions Panel
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SuggestionsPanel"
                Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20,10"
                Margin="0,0,0,8"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.18" ShadowDepth="3" Direction="270" Color="#000000" />
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform Y="30" />
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,2,16,0">
                            <TextBlock Text="💡" FontSize="15" VerticalAlignment="Center" TextAlignment="Center" />
                            <TextBlock x:Name="SuggestionLabel" Text="建议" Style="{StaticResource SectionLabel}" Margin="8,0,0,0" />
                        </StackPanel>

                <!-- 建议面板内容：三区纵向排列 -->
                <StackPanel Grid.Column="1" x:Name="SuggestionStackPanel"
                            Margin="0,0,0,0">
                    <!-- 通配匹配区 -->
                    <Border x:Name="WildcardSection"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       x:Name="WildcardSectionLabel"
                                       Text="通配匹配"
                                       Foreground="{StaticResource AccentLightBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <WrapPanel Grid.Row="1"
                                       x:Name="WildcardItems" />
                        </Grid>
                    </Border>

                    <!-- 拼写修正区 -->
                    <Border x:Name="FuzzySection"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       x:Name="FuzzySectionLabel"
                                       Text="相似拼写"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <WrapPanel Grid.Row="1"
                                       x:Name="FuzzyItems" />
                        </Grid>
                    </Border>

                    <!-- 拆分建议区 -->
                    <Border x:Name="CompoundSection"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       x:Name="CompoundSectionLabel"
                                       Text="拆分建议"
                                       Foreground="{StaticResource IgnoredBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <WrapPanel Grid.Row="1"
                                       x:Name="CompoundItems" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

                <!-- Stats Bar (Double-Bezel) -->
        <Border Grid.Row="3"
                CornerRadius="14"
                Background="#0E0E12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="1.5"
                Margin="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.18" ShadowDepth="3" Direction="270" Color="#000000" />
            </Border.Effect>
            <Border x:Name="StatsBar"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="12.5"
                    Padding="16,12"
                    MinHeight="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Available -->
                <Border Grid.Column="0" CornerRadius="6" Background="#0A2E1A" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="AvailableLabel"
                                   Text="可用：0"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Unavailable -->
                <Border Grid.Column="1" CornerRadius="6" Background="#2D1B1B" Padding="12,6" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="UnavailableLabel"
                                   Text="不可用：0"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Ignored -->
                <Border Grid.Column="2" CornerRadius="6" Background="#1A1A24" Padding="12,6" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource IgnoredBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="IgnoredLabel"
                                   Text="已忽略：0"
                                   Foreground="{StaticResource IgnoredBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Coverage progress bar + percentage -->
                <Grid Grid.Column="3"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      MaxWidth="300"
                      Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <!-- Track -->
                    <Border Grid.Column="0"
                            CornerRadius="1"
                            Background="#E8E8E8"
                            Height="8"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                        <Border x:Name="CoverageBar"
                                HorizontalAlignment="Left"
                                Width="0"
                                CornerRadius="1"
                                Background="{StaticResource AccentBrush}"
                                Height="8" />
                    </Border>
                    <!-- Percentage (fixed 50px width -> right-aligned) -->
                    <TextBlock Grid.Column="1"
                               x:Name="CoverageLabel"
                               Text="0%"
                               Foreground="{StaticResource AccentLightBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               Width="50" />
                </Grid>
            </Grid>
        </Border>
        </Border>
    </Grid>
    </Grid>
</Window>
