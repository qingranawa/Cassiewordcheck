<Window x:Class="CassieWordCheck.Views.WhitelistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="白名单管理"
        Width="460" Height="520"
        MinWidth="360" MinHeight="380"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="白名单管理" Style="{StaticResource SectionLabel}" FontSize="13" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewWordBox"
                             Grid.Column="0"
                             Style="{StaticResource ModernTextBox}"
                             FontSize="13"
                             KeyDown="OnNewWordKeyDown" />
                    <Button Grid.Column="1"
                            Style="{StaticResource AccentButton}"
                            Content="+ 添加"
                            Margin="8,0,0,0"
                            Padding="16,8"
                            Click="OnAddWord" />
                </Grid>
            </StackPanel>

            <Border Grid.Row="2"
                    CornerRadius="8"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="0"
                    Margin="0,10,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl x:Name="WhitelistItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,2"
                                        CornerRadius="6"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="8,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   FontSize="13"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Style="{StaticResource DangerButton}"
                                                Content="✕"
                                                Padding="8,2"
                                                FontSize="11"
                                                Click="OnRemoveWord"
                                                Tag="{Binding Text}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="EmptyLabel"
                       Grid.Row="2"
                       Text="暂无白名单单词，在上方输入添加。"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource ModernButton}"
                        Padding="14,6"
                        FontSize="12"
                        Click="OnImport">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="17" Width="16" Height="16" VerticalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Text="导入" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1"
                        Style="{StaticResource ModernButton}"
                        Padding="14,6"
                        FontSize="12"
                        Margin="8,0,0,0"
                        Click="OnExport">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="17" Width="16" Height="16" VerticalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Text="导出" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource DangerButton}"
                        Padding="14,6"
                        FontSize="12"
                        Click="OnClearAll">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="17" Width="16" Height="16" VerticalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Text="清空全部" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
