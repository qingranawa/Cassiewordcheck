<Window x:Class="CassieWordCheck.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 CASSIE CWC Tool"
        Width="540" Height="620"
        MinWidth="440" MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        AllowsTransparency="False"
        Loaded="OnLoaded">

    <Window.Resources>
        <Storyboard x:Key="ContentFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="12" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ContentFadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-8" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- 主容器：外层带氛围光晕 -->
    <Grid>
        <!-- 氛围光晕装饰 -->
        <Ellipse Width="280" Height="280"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.08"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-60,-60,0" />

        <Border Margin="1" CornerRadius="14"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.35"
                                  ShadowDepth="6" Direction="270" Color="#000000" />
            </Border.Effect>
            <Grid Margin="28,28,28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ═══ 头部：图标 + 标题 + 版本 ═══ -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 应用图标 -->
                    <Border Grid.Column="0"
                            Width="52" Height="52"
                            CornerRadius="10"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Background="Transparent"
                            VerticalAlignment="Center"
                            x:Name="AppIconBorder"
                            ClipToBounds="True">
                        <Image x:Name="AppIconImage" Width="52" Height="52"
                               Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="CASSIE CWC Tool"
                                   FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionLabel" Text="版本 2.3.2"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>

                <!-- ═══ 装饰分割线 ═══ -->
                <Rectangle Grid.Row="1" Height="1" Margin="0,0,0,16"
                           Fill="{StaticResource BorderBrush}" Opacity="0.5" />

                <!-- ═══ 标签页 ═══ -->
                <Grid x:Name="TabGrid" Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 功能标签 -->
                    <Border Grid.Column="0" Padding="0,0,0,8">
                        <TextBlock x:Name="FeaturesTab"
                                   Text="项目功能"
                                   FontSize="13" FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseDown="OnShowFeatures">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 更新日志标签 -->
                    <Border Grid.Column="1" Margin="28,0,0,0" Padding="0,0,0,8">
                        <TextBlock x:Name="ChangelogTab"
                                   Text="更新日志"
                                   FontSize="13" FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseDown="OnShowChangelog">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 关于标签 -->
                    <Border Grid.Column="2" Margin="28,0,0,0" Padding="0,0,0,8">
                        <TextBlock x:Name="AboutInfoTab"
                                   Text="关于"
                                   FontSize="13" FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseDown="OnShowAboutInfo">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 声明标签 -->
                    <Border Grid.Column="3" Margin="28,0,0,0" Padding="0,0,0,8">
                        <TextBlock x:Name="DisclaimerTab"
                                   Text="声明"
                                   FontSize="13" FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseDown="OnShowDisclaimer">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 底部指示条 -->
                    <Border x:Name="TabIndicator"
                            Grid.Column="0" Grid.ColumnSpan="4"
                            Width="36" Height="2.5"
                            CornerRadius="2"
                            Background="{StaticResource AccentGradientBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,0" />
                </Grid>

                <!-- ═══ 内容区域（Markdown 渲染） ═══ -->
                <FlowDocumentScrollViewer x:Name="ContentArea"
                                          Grid.Row="3"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="0"
                                          Margin="0"
                                          Opacity="0"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsToolBarVisible="False"
                                          PreviewMouseDown="OnContentPreviewMouseDown">
                    <FlowDocumentScrollViewer.RenderTransform>
                        <TranslateTransform Y="12" />
                    </FlowDocumentScrollViewer.RenderTransform>
                </FlowDocumentScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
