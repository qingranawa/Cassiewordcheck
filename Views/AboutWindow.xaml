<Window x:Class="CassieWordCheck.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 CASSIE CWC Tool"
        Width="540" Height="620"
        MinWidth="440" MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        AllowsTransparency="False"
        Loaded="OnLoaded">

    <Window.Resources>
        <Storyboard x:Key="ContentFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="12" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ContentFadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-8" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- 氛围光晕装饰 -->
    <Grid>
        <Ellipse Width="280" Height="280"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.08"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-60,-60,0" />

        <!-- ═══ 外层 Double-Bezel 结构 ═══ -->
        <Border Margin="1" CornerRadius="16"
                Background="#0E0E12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.35"
                                  ShadowDepth="6" Direction="270" Color="#000000" />
            </Border.Effect>

            <!-- 内层主卡片 -->
            <Border CornerRadius="14"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="24,24,24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ═══ 头部：图标 + 标题 + 版本 ═══ -->
                    <Grid Grid.Row="0" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 应用图标（AAA.JPG）+ Ellipse 后备 -->
                        <Border Grid.Column="0"
                                Width="52" Height="52"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Background="#0E0E12"
                                VerticalAlignment="Center">
                            <Grid>
                                <Ellipse Width="36" Height="36"
                                         Fill="{StaticResource AccentGradientBrush}"
                                         Opacity="0.25"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center" />
                                <Image x:Name="AppIconImage" Width="50" Height="50"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="11" RadiusY="11"
                                                           Rect="0,0,50,50" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <!-- 标题 + 版本徽章 -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="CASSIE CWC Tool"
                                           FontSize="18" FontWeight="700" />
                                <Border CornerRadius="4"
                                        Background="#2D1B1B"
                                        BorderBrush="#3D2020"
                                        BorderThickness="1"
                                        Padding="6,2"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="VersionBadge"
                                               Text="v2.3.6"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrorBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="VersionLabel" Text="版本 2.3.6"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock Text="🔗" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock FontSize="10"
                                           Foreground="{StaticResource AccentLightBrush}"
                                           VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Hyperlink Foreground="{StaticResource AccentLightBrush}"
                                               NavigateUri="https://github.com/qingranawa/Cassiewordcheck"
                                               RequestNavigate="OnGitHubLink">
                                        github.com/qingranawa/Cassiewordcheck
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- ═══ 渐变分割线 ═══ -->
                    <Rectangle Grid.Row="1" Height="1" Margin="0,0,0,16"
                               Opacity="0.4">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0.0" />
                                <GradientStop Color="#D9586B" Offset="0.5" />
                                <GradientStop Color="Transparent" Offset="1.0" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ═══ 卡片式标签页 ═══ -->
                    <Grid x:Name="TabGrid" Grid.Row="2" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 功能 -->
                        <Border x:Name="FeaturesTab"
                                Grid.Column="0"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                MouseDown="OnShowFeatures">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0E0E12" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Background" Value="#1A1A2E" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="6" Opacity="0.2" ShadowDepth="2" Direction="270" Color="#D9586B" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="项目功能"
                                       FontSize="12" FontWeight="SemiBold"
                                       x:Name="FeaturesTabText">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="Active">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- 更新日志 -->
                        <Border x:Name="ChangelogTab"
                                Grid.Column="1"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="6,0,6,0"
                                Cursor="Hand"
                                MouseDown="OnShowChangelog">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0E0E12" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Background" Value="#1A1A2E" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="6" Opacity="0.2" ShadowDepth="2" Direction="270" Color="#D9586B" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="更新日志"
                                       FontSize="12" FontWeight="SemiBold"
                                       x:Name="ChangelogTabText">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="Active">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- 关于 -->
                        <Border x:Name="AboutInfoTab"
                                Grid.Column="2"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="6,0,6,0"
                                Cursor="Hand"
                                MouseDown="OnShowAboutInfo">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0E0E12" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Background" Value="#1A1A2E" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="6" Opacity="0.2" ShadowDepth="2" Direction="270" Color="#D9586B" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="关于"
                                       FontSize="12" FontWeight="SemiBold"
                                       x:Name="AboutInfoTabText">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="Active">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- 声明 -->
                        <Border x:Name="DisclaimerTab"
                                Grid.Column="3"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="6,0,0,0"
                                Cursor="Hand"
                                MouseDown="OnShowDisclaimer">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0E0E12" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="Active">
                                            <Setter Property="Background" Value="#1A1A2E" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="6" Opacity="0.2" ShadowDepth="2" Direction="270" Color="#D9586B" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="声明"
                                       FontSize="12" FontWeight="SemiBold"
                                       x:Name="DisclaimerTabText">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="Active">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- ═══ 内容区域（内嵌卡片） ═══ -->
                    <Border Grid.Row="3"
                            CornerRadius="10"
                            Background="#0E0E12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="0">
                        <FlowDocumentScrollViewer x:Name="ContentArea"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Padding="14,12"
                                                  Margin="0"
                                                  Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsToolBarVisible="False"
                                                  PreviewMouseDown="OnContentPreviewMouseDown">
                            <FlowDocumentScrollViewer.RenderTransform>
                                <TranslateTransform Y="12" />
                            </FlowDocumentScrollViewer.RenderTransform>
                        </FlowDocumentScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
