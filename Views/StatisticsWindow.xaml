<Window x:Class="CassieWordCheck.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       
        Title="统计面板"
        Width="720" Height="520"
        MinWidth="560" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Loaded="OnWindowLoaded">

    <Window.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1" />
    </Window.RenderTransform>

    <Border Margin="1" CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="16,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="17" Width="16" Height="16" VerticalAlignment="Center" TextAlignment="Center" />
                                <TextBlock x:Name="TitleLabel"
                                           Style="{StaticResource SectionLabel}"
                                           FontSize="14" Margin="6,0,0,0" />
                            </StackPanel>
                <ComboBox Grid.Column="2"
                          x:Name="ViewSelector"
                          Style="{StaticResource ModernComboBox}"
                          Width="150"
                          VerticalAlignment="Center"
                          SelectionChanged="OnViewChanged">
                    <ComboBoxItem IsSelected="True" Content="覆盖率趋势" Tag="coverage" />
                    <ComboBoxItem Content="不可用词趋势" Tag="unavailable" />
                </ComboBox>
            </Grid>

            <!-- 图表区域 -->
            <Border Grid.Row="1"
                    CornerRadius="8"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="0">
                <Grid>
                    <Canvas x:Name="ChartCanvas" />
                    <TextBlock x:Name="EmptyLabel"
                               Text="暂无历史数据"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- 底部汇总（间距与图表左边缘对齐） -->
            <Border Grid.Row="2"
                    x:Name="SummaryBar"
                    Margin="0,16,0,0"
                    CornerRadius="8"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="6" Background="#1A1A2E" Padding="12,6">
                        <TextBlock x:Name="TotalChecksLabel"
                                   Text="检查：0 次"
                                   Foreground="{StaticResource AccentLightBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}" />
                    </Border>
                    <Border Grid.Column="1" CornerRadius="6" Background="#0A2E1A" Padding="12,6" Margin="8,0,0,0">
                        <TextBlock x:Name="AvgCoverageLabel"
                                   Text="平均：0%"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}" />
                    </Border>
                    <Border Grid.Column="2" CornerRadius="6" Background="#2D1B1B" Padding="12,6" Margin="8,0,0,0">
                        <TextBlock x:Name="WorstCoverageLabel"
                                   Text="最低：0%"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}" />
                    </Border>
                    <TextBlock Grid.Column="4"
                               x:Name="TotalUnavailableLabel"
                               Text="不可用词合计：0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
