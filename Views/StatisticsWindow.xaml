<Window x:Class="CassieWordCheck.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="统计面板"
        Width="720" Height="520"
        MinWidth="560" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Loaded="OnWindowLoaded">

    <Window.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1" />
    </Window.RenderTransform>

    <Grid>
        <Ellipse Width="260" Height="260"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.06"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-60,-60,0"
                 IsHitTestVisible="False" />

        <Border Margin="1" CornerRadius="14"
                Background="#0E0E12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270" Color="#000000" />
            </Border.Effect>
            <Border CornerRadius="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="20,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📈" FontSize="16" VerticalAlignment="Center" TextAlignment="Center" />
                            <TextBlock x:Name="TitleLabel"
                                       Style="{StaticResource SectionLabel}"
                                       FontSize="14" Margin="6,0,0,0" />
                        </StackPanel>
                        <ComboBox Grid.Column="2"
                                  x:Name="ViewSelector"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="150"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnViewChanged">
                            <ComboBoxItem IsSelected="True" Content="覆盖率趋势" Tag="coverage" />
                            <ComboBoxItem Content="不可用词趋势" Tag="unavailable" />
                        </ComboBox>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                CornerRadius="8"
                                Background="{StaticResource BgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="0">
                            <Grid>
                                <Canvas x:Name="ChartCanvas" />
                                <TextBlock x:Name="EmptyLabel"
                                           Text="暂无历史数据"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                CornerRadius="8"
                                Background="{StaticResource BgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="16,10"
                                Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="6" Background="#1A1A2E" Padding="12,6">
                                    <TextBlock x:Name="TotalChecksLabel"
                                               Text="检查：0 次"
                                               Foreground="{StaticResource AccentLightBrush}"
                                               FontSize="11" FontFamily="{StaticResource MonoFont}" />
                                </Border>
                                <Border Grid.Column="1" CornerRadius="6" Background="#0A2E1A" Padding="12,6" Margin="8,0,0,0">
                                    <TextBlock x:Name="AvgCoverageLabel"
                                               Text="平均：0%"
                                               Foreground="{StaticResource SuccessBrush}"
                                               FontSize="11" FontFamily="{StaticResource MonoFont}" />
                                </Border>
                                <Border Grid.Column="2" CornerRadius="6" Background="#2D1B1B" Padding="12,6" Margin="8,0,0,0">
                                    <TextBlock x:Name="WorstCoverageLabel"
                                               Text="最低：0%"
                                               Foreground="{StaticResource ErrorBrush}"
                                               FontSize="11" FontFamily="{StaticResource MonoFont}" />
                                </Border>
                                <TextBlock Grid.Column="4"
                                           x:Name="TotalUnavailableLabel"
                                           Text="不可用词合计：0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" FontFamily="{StaticResource MonoFont}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
