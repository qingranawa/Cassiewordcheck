<Window x:Class="CassieWordCheck.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="500" Height="540"
        MinWidth="420" MinHeight="460"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Loaded="OnWindowLoaded">

    <Grid>
        <!-- 氛围光晕装饰 -->
        <Ellipse Width="220" Height="220"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.06"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-60,-60,0"
                 IsHitTestVisible="False" />

        <!-- 外层 Double-Bezel -->
        <Border Margin="1" CornerRadius="14"
                Background="#0E0E12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270" Color="#000000" />
            </Border.Effect>
            <Border CornerRadius="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="20,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="TitleLabel" Text="设 置"
                               Style="{StaticResource SectionLabel}"
                               FontSize="13" Margin="0,0,0,12" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>

                            <CheckBox x:Name="IgnoreChineseCheck"
                                      Style="{StaticResource ModernCheckBox}"
                                      Content="忽略中文字符"
                                      Margin="0,0,0,10" />
                            <TextBlock Text="CASSIE 无法读出中文。开启后将跳过中文字符。"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,10" />

                            <CheckBox x:Name="FilterFormattingCheck"
                                      Style="{StaticResource ModernCheckBox}"
                                      Content="过滤格式标记"
                                      Margin="0,0,0,10" />
                            <TextBlock Text="忽略 link、&lt;size&gt;、&lt;color&gt;、&lt;split&gt; 等标签以及标点符号（。，.,?）。"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,10" />

                            <CheckBox x:Name="FilterNamingCheck"
                                      Style="{StaticResource ModernCheckBox}"
                                      Content="过滤命名标记"
                                      Margin="0,0,0,10" />
                            <TextBlock Text="忽略 MTF、UIU、GOC、CI、NTF、GRU、FBI 等阵营缩写以及希腊字母、北约代号（Alpha-1）。"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,10" />

                            <!-- 渐变分割线 -->
                            <Rectangle Height="1" Margin="0,0,0,10" Opacity="0.4">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#D9586B" Offset="0.5" />
                                        <GradientStop Color="Transparent" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <StackPanel>
                                <TextBlock Text="界面语言" Style="{StaticResource SectionLabel}" Margin="0,0,0,10" />
                                <ComboBox x:Name="LanguageCombo"
                                          Style="{StaticResource ModernComboBox}"
                                          Width="200"
                                          Height="32"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,10"
                                          SelectionChanged="OnLanguageChanged" />
                            </StackPanel>

                            <!-- 渐变分割线 -->
                            <Rectangle Height="1" Margin="0,0,0,10" Opacity="0.4">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#D9586B" Offset="0.5" />
                                        <GradientStop Color="Transparent" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <StackPanel>
                                <TextBlock Text="词库文件路径" Style="{StaticResource SectionLabel}" Margin="0,0,0,10" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="WordlistPathBox"
                                             Grid.Column="0"
                                             Style="{StaticResource ModernTextBox}"
                                             IsReadOnly="True"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             FontSize="12" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ModernButton}"
                                            Content="浏览..."
                                            Margin="8,0,0,0"
                                            Padding="16,8"
                                            Click="OnBrowseWordlist" />
                                </Grid>
                            </StackPanel>

                            <Separator BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,10" />

                            <StackPanel>
                                <TextBlock Text="字体大小" Style="{StaticResource SectionLabel}" Margin="0,0,0,10" />
                                <ComboBox x:Name="FontSizeCombo"
                                          Style="{StaticResource ModernComboBox}"
                                          Width="120"
                                          Height="32"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,10">
                                    <ComboBoxItem Content="10" />
                                    <ComboBoxItem Content="11" />
                                    <ComboBoxItem Content="12" />
                                    <ComboBoxItem Content="13" />
                                    <ComboBoxItem Content="14" IsSelected="True" />
                                    <ComboBoxItem Content="15" />
                                    <ComboBoxItem Content="16" />
                                    <ComboBoxItem Content="18" />
                                    <ComboBoxItem Content="20" />
                                    <ComboBoxItem Content="22" />
                                    <ComboBoxItem Content="24" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel>
                                <CheckBox x:Name="WordWrapCheck"
                                          Style="{StaticResource ModernCheckBox}"
                                          Content="自动换行"
                                          Margin="0,0,0,10" />
                                <TextBlock Text="关闭后输入框将横向滚动，适合长单行文本。"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="28,0,0,10" />
                            </StackPanel>

                            <Separator BorderBrush="{StaticResource BorderBrush}" />

                            <Button x:Name="UpdateCheckButton"
                                    Style="{StaticResource ModernButton}"
                                    Content="↻ 检查更新"
                                    Padding="14,8"
                                    HorizontalAlignment="Left"
                                    Click="OnCheckUpdate" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource ModernButton}"
                                Content="恢复默认"
                                Foreground="{StaticResource TextMutedBrush}"
                                Click="OnResetDefaults" />

                        <Button Grid.Column="2"
                                Style="{StaticResource AccentButton}"
                                Content="保存并关闭"
                                Padding="24,8"
                                Click="OnSave" />
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
