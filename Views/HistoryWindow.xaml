<Window x:Class="CassieWordCheck.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检查历史"
        Width="600" Height="520"
        MinWidth="460" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Grid>
        <Ellipse Width="240" Height="240"
                 Fill="{StaticResource AccentGradientBrush}"
                 Opacity="0.06"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-60,-60,0"
                 IsHitTestVisible="False" />

        <!-- 外层 Double-Bezel -->
        <Border Margin="1" CornerRadius="14"
                Background="#0E0E12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270" Color="#000000" />
            </Border.Effect>
            <Border CornerRadius="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="20,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题 + 清空按钮 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="检查历史"
                                   Style="{StaticResource SectionLabel}"
                                   FontSize="13" />
                        <Button Grid.Column="2"
                                x:Name="ClearAllButton"
                                Style="{StaticResource DangerButton}"
                                Padding="14,6"
                                FontSize="12"
                                Click="OnClearAll">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontSize="14" VerticalAlignment="Center" TextAlignment="Center" />
                                <TextBlock Text="清空全部" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- 历史列表 -->
                    <Border Grid.Row="1" CornerRadius="8"
                            Background="{StaticResource BgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="4"
                            Margin="0,12,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HistoryList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="2,2" CornerRadius="6"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" Padding="10,8"
                                                Cursor="Hand"
                                                MouseDown="OnItemClick">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding TimeLabel}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource AccentLightBrush}"
                                                               FontFamily="{StaticResource MonoFont}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding StatsLabel}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource MonoFont}" />
                                                </Grid>
                                                <TextBlock Text="{Binding Preview}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border CornerRadius="4"
                                                        Padding="6,2"
                                                        Background="#1A1A2E"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding ResultPreview}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="32" />
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- 空状态提示 -->
                    <TextBlock x:Name="EmptyLabel" Grid.Row="1"
                               Text="暂无检查记录"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />

                    <!-- 底部 -->
                    <TextBlock Grid.Row="2" Margin="0,12,0,0"
                               Text="点击条目可恢复文本到主窗口"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
